{
  "name": "moldy-pumpkins",
  "version": "1.0.0",
  "description": "Publishes curated movie & TV browse lists as JSON for Radarr/Sonarr import lists",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --import tsx --test \"test/*.test.ts\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node --import tsx src/local.ts",
    "start:dry": "DRY_RUN=true npm start",
    "deploy": "sam build && sam deploy",
    "deploy:guided": "sam build && sam deploy --guided"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joshuahiggins/moldy-pumpkins.git"
  },
  "keywords": [
    "movies",
    "tv",
    "radarr",
    "sonarr",
    "import-list"
  ],
  "author": "Joshua Higgins <hello@joshuahiggins.com>",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "cheerio": "^1.0.0",
    "esbuild": "^0.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.8.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  }
}
